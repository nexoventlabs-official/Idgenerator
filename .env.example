# ══════════════════════════════════════════════════════════════════
#  VOTER ID CARD GENERATOR - Environment Configuration
# ══════════════════════════════════════════════════════════════════
#
#  SECURITY WARNING:
#  - NEVER commit the actual .env file to Git
#  - Rotate ALL credentials after any exposure
#  - Use strong, unique passwords for each service
#
# ══════════════════════════════════════════════════════════════════

# ── MySQL (Voter data — READ-ONLY, multi-table: tbl_voters_*) ────
# Remote DB with 234 assembly voter tables + tbl_assembly_consitituency mapping
MYSQL_HOST=your_mysql_host
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_VOTERS_DB=your_voters_database
MYSQL_VOTERS_TABLE=voters

# ── MySQL (Generated data — READ/WRITE, same or separate DB) ─────
MYSQL_DB=your_generated_database

# ── Environment ──────────────────────────────────────────────────
FLASK_ENV=development

# ── Cloudinary (Photo & Card Storage) ─────────────────────────────
# Sign up at: https://cloudinary.com
# Get credentials from: Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_PHOTO_FOLDER=member_photos
CLOUDINARY_CARDS_FOLDER=generated_cards

# ── Flask Application ─────────────────────────────────────────────
# Generate secret: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET=your_secret_key_here_minimum_32_characters
BASE_URL=http://127.0.0.1:5000

# ── Admin Credentials ─────────────────────────────────────────────
# IMPORTANT: Use strong, unique credentials
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_strong_admin_password

# ── SMS OTP Service (2Factor.in) ──────────────────────────────────
# Sign up at: https://2factor.in
# Get API key from: Dashboard → API Keys
SMS_API_KEY=your_sms_api_key

# ── WhatsApp Business API (Meta) ──────────────────────────────────
# Set up at: https://developers.facebook.com/apps/
WHATSAPP_BUSINESS_ID=your_business_id
WHATSAPP_APP_ID=your_app_id
WHATSAPP_WABA_ID=your_waba_id
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_VERIFY_TOKEN=your_verify_token

# ── Redis Cache (Optional - for dashboard performance) ────────────
# Sign up at: https://redis.com/try-free/
# Or use local Redis: redis://localhost:6379/0
# Leave empty to disable caching (app will work without it)
REDIS_URL=redis://default:PASSWORD@host:port/0

# ── YouTube Data API (Optional - for external integrations) ───────
# Get API key from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key

# ── WhatsApp Channel (Optional - for user engagement) ─────────────
WHATSAPP_CHANNEL_URL=https://whatsapp.com/channel/your_channel_id
